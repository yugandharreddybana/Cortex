{
  "metadata": {
    "appName": "Cortex",
    "date": "2025-03-12",
    "version": "1.0",
    "analysisScope": "Complete API surface - 14 controllers, 40+ endpoints",
    "architecture": "Next.js BFF → Java Spring Boot Backend",
    "authMethod": "JWT + iron-session encrypted cookie"
  },
  "apiEndpointMapping": {
    "AUTHENTICATION": {
      "signup": {
        "bffRoute": "POST /api/auth/signup",
        "backendEndpoint": "POST /api/v1/auth/signup",
        "controller": "AuthController::signup",
        "authRequired": false,
        "requestFields": {
          "email": { "type": "string", "required": true, "validation": "email" },
          "password": { "type": "string", "required": true, "validation": "8-128 chars" },
          "fullName": { "type": "string", "required": true, "validation": "max 100 chars" },
          "tier": { "type": "string", "required": false, "default": "starter" }
        },
        "responseFields": {
          "success": { "type": "boolean" },
          "user": {
            "email": "string",
            "tier": "string"
          }
        },
        "databaseOperations": [
          "userRepository.findByEmail(email) - check if exists",
          "User.create() with bcrypt hashed password",
          "userRepository.save(user)",
          "authService.generateToken(userId)"
        ],
        "createdTables": ["users"],
        "httpStatus": 201
      },
      "login": {
        "bffRoute": "POST /api/auth/login",
        "backendEndpoint": "POST /api/v1/auth/login",
        "controller": "AuthController::login",
        "authRequired": false,
        "requestFields": {
          "email": { "type": "string", "required": true },
          "password": { "type": "string", "required": true }
        },
        "responseFields": {
          "success": { "type": "boolean" },
          "user": {
            "email": "string",
            "tier": "string"
          }
        },
        "databaseOperations": [
          "userRepository.findByEmail(email)",
          "passwordEncoder.matches(password, user.passwordHash)",
          "authService.generateToken(userId)"
        ],
        "httpStatus": 200
      },
      "refresh": {
        "bffRoute": "POST /api/auth/refresh",
        "backendEndpoint": "POST /api/v1/refresh-token",
        "controller": "ExtensionTokenController::refreshToken",
        "authRequired": true,
        "requestFields": {},
        "responseFields": {
          "token": "string",
          "user": {
            "id": "UUID",
            "email": "string",
            "tier": "string"
          }
        },
        "databaseOperations": [
          "userRepository.findById(userId)",
          "authService.refresh(userId)"
        ],
        "httpStatus": 200
      },
      "getMe": {
        "bffRoute": "GET /api/auth/me",
        "backendEndpoint": "GET /api/v1/user/profile",
        "controller": "UserController::getProfile",
        "authRequired": true,
        "requestFields": {},
        "responseFields": {
          "authenticated": "boolean",
          "user": {
            "id": "UUID",
            "email": "string",
            "fullName": "string",
            "avatarUrl": "string",
            "tier": "string",
            "createdAt": "timestamp"
          }
        },
        "databaseOperations": [
          "userRepository.findById(userId)"
        ],
        "httpStatus": 200
      },
      "logout": {
        "bffRoute": "POST /api/auth/logout",
        "backendEndpoint": null,
        "controller": null,
        "authRequired": false,
        "isClientOnly": true,
        "requestFields": {},
        "responseFields": {
          "success": "boolean"
        },
        "databaseOperations": [],
        "httpStatus": 200
      },
      "extensionToken": {
        "bffRoute": "POST /api/extension-token",
        "backendEndpoint": "POST /api/v1/extension-token",
        "controller": "ExtensionTokenController::issueExtensionToken",
        "authRequired": true,
        "requestFields": {},
        "responseFields": {
          "token": "string"
        },
        "databaseOperations": [
          "authService.generateExtensionToken(userId)"
        ],
        "httpStatus": 200
      }
    },
    "HIGHLIGHTS": {
      "list": {
        "bffRoute": "GET /api/highlights",
        "backendEndpoint": "GET /api/v1/highlights",
        "controller": "HighlightController::list",
        "authRequired": true,
        "requestFields": {},
        "responseFields": {
          "type": "array",
          "items": {
            "id": "string",
            "text": "string",
            "source": "string",
            "url": "string",
            "topic": "string",
            "topicColor": "string",
            "savedAt": "string",
            "folder": "string",
            "folderId": "string",
            "note": "string",
            "tags": ["string"],
            "isCode": "boolean",
            "isFavorite": "boolean",
            "isArchived": "boolean",
            "isPinned": "boolean",
            "highlightColor": "string",
            "isAI": "boolean",
            "chatName": "string",
            "chatUrl": "string",
            "resourceType": "string",
            "videoTimestamp": "integer",
            "linkAccess": "string",
            "defaultLinkRole": "string",
            "isDeleted": "boolean"
          }
        },
        "databaseOperations": [
          "highlightRepository.findByUserIdOrderByCreatedAtDesc(userId)"
        ],
        "tables": ["highlights", "highlight_tags", "tags"],
        "httpStatus": 200
      },
      "create": {
        "bffRoute": "POST /api/highlights",
        "backendEndpoint": "POST /api/v1/highlights",
        "controller": "HighlightController::create",
        "authRequired": true,
        "requestFields": {
          "id": { "type": "string", "required": false },
          "text": { "type": "string", "required": true },
          "source": { "type": "string", "required": false },
          "url": { "type": "string", "required": false },
          "topic": { "type": "string", "required": false },
          "topicColor": { "type": "string", "required": false },
          "savedAt": { "type": "string", "required": false },
          "folder": { "type": "string", "required": false },
          "folderId": { "type": "string", "required": false },
          "note": { "type": "string", "required": false },
          "tags": { "type": "array<string>", "required": false },
          "isCode": { "type": "boolean", "required": false },
          "isFavorite": { "type": "boolean", "required": false },
          "isArchived": { "type": "boolean", "required": false },
          "isPinned": { "type": "boolean", "required": false },
          "highlightColor": { "type": "string", "required": false },
          "isAI": { "type": "boolean", "required": false },
          "chatName": { "type": "string", "required": false },
          "chatUrl": { "type": "string", "required": false },
          "resourceType": { "type": "string", "required": false },
          "videoTimestamp": { "type": "integer", "required": false }
        },
        "responseFields": {
          "id": "string",
          "text": "string",
          "source": "string",
          "url": "string",
          "topic": "string",
          "topicColor": "string",
          "savedAt": "string",
          "folderId": "string",
          "note": "string",
          "tags": ["string"],
          "isCode": "boolean",
          "isFavorite": "boolean",
          "isArchived": "boolean",
          "isPinned": "boolean",
          "highlightColor": "string",
          "isAI": "boolean",
          "chatName": "string",
          "chatUrl": "string",
          "resourceType": "string",
          "videoTimestamp": "integer",
          "isDeleted": "boolean"
        },
        "databaseOperations": [
          "Highlight.fromDTO(dto, user)",
          "applyTags(h, dto.tags, user) - create missing tags",
          "highlightRepository.save(h)",
          "webSocketService.sendToUser(userId, \"/topic/highlights\", highlightDTO)"
        ],
        "createdTables": ["highlights", "highlight_tags"],
        "httpStatus": 201,
        "accessControl": "OWNER"
      },
      "update": {
        "bffRoute": "PUT /api/highlights/{id}",
        "backendEndpoint": "PUT /api/v1/highlights/{id}",
        "controller": "HighlightController::update",
        "authRequired": true,
        "accessControl": "EDITOR",
        "requestFields": {
          "note": "optional string",
          "tags": "optional array",
          "isFavorite": "optional boolean"
        },
        "databaseOperations": [
          "highlightRepository.findByIdAndUserId(id, userId)",
          "applyDTO(h, dto)",
          "applyTags(h, dto.tags, user)",
          "highlightRepository.save(h)",
          "webSocketService.sendToUser(userId, \"/topic/highlights/updated\", highlightDTO)"
        ],
        "httpStatus": 200
      },
      "patch": {
        "bffRoute": "PATCH /api/highlights/{id}",
        "backendEndpoint": "PATCH /api/v1/highlights/{id}",
        "controller": "HighlightController::patch",
        "authRequired": true,
        "accessControl": "EDITOR",
        "httpStatus": 200
      },
      "delete": {
        "bffRoute": "DELETE /api/highlights/{id}",
        "backendEndpoint": "DELETE /api/v1/highlights/{id}",
        "controller": "HighlightController::delete",
        "authRequired": true,
        "accessControl": "OWNER",
        "databaseOperations": [
          "highlightRepository.softDeleteByIdAndUserId(id, userId, userId, Instant.now())",
          "Sets: is_deleted=true, deleted_by_user_id=userId, deleted_at=now()",
          "webSocketService.sendToUser(userId, \"/topic/highlights/deleted\", id)"
        ],
        "responseFields": {
          "ok": "boolean"
        },
        "httpStatus": 200
      },
      "sync": {
        "bffRoute": "PUT /api/highlights/sync",
        "backendEndpoint": "PUT /api/v1/highlights/sync",
        "controller": "HighlightController::sync",
        "authRequired": true,
        "requestFields": {
          "type": "array<HighlightDTO>"
        },
        "databaseOperations": [
          "highlightRepository.findAllByUserIdInclandDeleted(userId)",
          "For each incoming DTO: upsert (create or update)",
          "Note: Only UPSERTS, does NOT delete missing items"
        ],
        "httpStatus": 200
      }
    },
    "FOLDERS": {
      "list": {
        "bffRoute": "GET /api/folders",
        "backendEndpoint": "GET /api/v1/folders",
        "controller": "FolderController::list",
        "authRequired": true,
        "databaseOperations": [
          "folderService.getFoldersByUserId(userId)",
          "permissionService.getEffectiveRole(userId, folderId) for each"
        ],
        "httpStatus": 200
      },
      "create": {
        "bffRoute": "POST /api/folders",
        "backendEndpoint": "POST /api/v1/folders",
        "controller": "FolderController::create",
        "authRequired": true,
        "requestFields": {
          "id": { "type": "string", "required": false },
          "name": { "type": "string", "required": true },
          "emoji": { "type": "string", "required": false, "default": "📁" },
          "parentId": { "type": "string", "required": false },
          "isPinned": { "type": "boolean", "required": false },
          "linkAccess": { "type": "string", "required": false, "enum": ["RESTRICTED", "PUBLIC"] },
          "defaultLinkRole": { "type": "string", "required": false, "enum": ["VIEWER", "EDITOR"] }
        },
        "databaseOperations": [
          "Folder.fromDTO(dto, user)",
          "folderService.getFolderByIdAndUserId(parentId, userId) - validate parent",
          "folder.setParentFolder(parent)",
          "folderRepository.save(folder)"
        ],
        "httpStatus": 201,
        "accessControl": "OWNER"
      },
      "update": {
        "bffRoute": "PUT /api/folders/{id}",
        "backendEndpoint": "PUT /api/v1/folders/{id}",
        "controller": "FolderController::update",
        "authRequired": true,
        "accessControl": "EDITOR",
        "httpStatus": 200
      },
      "patch": {
        "bffRoute": "PATCH /api/folders/{id}",
        "backendEndpoint": "PATCH /api/v1/folders/{id}",
        "controller": "FolderController::patch",
        "authRequired": true,
        "accessControl": "EDITOR",
        "httpStatus": 200
      },
      "delete": {
        "bffRoute": "DELETE /api/folders/{id}",
        "backendEndpoint": "DELETE /api/v1/folders/{id}",
        "controller": "FolderController::delete",
        "authRequired": true,
        "accessControl": "EDITOR",
        "queryParameters": {
          "keepHighlights": { "type": "boolean", "default": false, "description": "If true, move highlights to root; else delete them too" }
        },
        "databaseOperations": [
          "folderService.deleteFolder(id, userId, keepHighlights)",
          "Recursively soft-delete child folders and highlights",
          "Or move highlights to root if keepHighlights=true"
        ],
        "httpStatus": 200
      },
      "duplicate": {
        "bffRoute": "POST /api/folders/{id}/duplicate",
        "backendEndpoint": "POST /api/v1/folders/{id}/duplicate",
        "controller": "FolderController::duplicate",
        "authRequired": true,
        "accessControl": "VIEWER (minimum)",
        "description": "Deep-clone a shared folder to caller's library, then revoke access to original",
        "databaseOperations": [
          "permissionService.getEffectiveRole(callerId, id)",
          "folderService.deepCloneFolder(id, callerId, null) - recursive copy",
          "folderService.revokeAccessAfterDuplicate(callerId, id) - delete permission"
        ],
        "httpStatus": 201
      },
      "sync": {
        "bffRoute": "PUT /api/folders/sync",
        "backendEndpoint": "PUT /api/v1/folders/sync",
        "controller": "FolderController::sync",
        "authRequired": true,
        "databaseOperations": [
          "folderService.syncFolders(user, dtos)",
          "Upsert each folder (create or update)",
          "Maintain parent-child relationships"
        ],
        "httpStatus": 200
      }
    },
    "TAGS": {
      "list": {
        "bffRoute": "GET /api/tags",
        "backendEndpoint": "GET /api/v1/tags",
        "controller": "TagController::list",
        "authRequired": true,
        "databaseOperations": [
          "tagService.getTagsByUserId(userId)"
        ],
        "httpStatus": 200
      },
      "create": {
        "bffRoute": "POST /api/tags",
        "backendEndpoint": "POST /api/v1/tags",
        "controller": "TagController::create",
        "authRequired": true,
        "requestFields": {
          "id": { "type": "string", "required": false },
          "name": { "type": "string", "required": true },
          "color": { "type": "string", "required": true }
        },
        "databaseOperations": [
          "new Tag(id, name, color, user)",
          "tagService.createTag(tag)"
        ],
        "httpStatus": 201
      },
      "update": {
        "bffRoute": "PATCH /api/tags/{id}",
        "backendEndpoint": "PATCH /api/v1/tags/{id}",
        "controller": "TagController::update",
        "authRequired": true,
        "httpStatus": 200
      },
      "delete": {
        "bffRoute": "DELETE /api/tags/{id}",
        "backendEndpoint": "DELETE /api/v1/tags/{id}",
        "controller": "TagController::delete",
        "authRequired": true,
        "databaseOperations": [
          "tagService.deleteTag(id, user)",
          "Delete highlight_tags junction records",
          "Delete tag from tags table"
        ],
        "httpStatus": 200
      },
      "sync": {
        "bffRoute": "PUT /api/tags/sync",
        "backendEndpoint": "PUT /api/v1/tags/sync",
        "controller": "TagController::sync",
        "authRequired": true,
        "httpStatus": 200
      }
    },
    "PERMISSIONS": {
      "grant": {
        "bffRoute": "POST /api/permissions",
        "backendEndpoint": "POST /api/v1/permissions",
        "controller": "PermissionController::grant",
        "authRequired": true,
        "accessControl": "OWNER-only",
        "requestFields": {
          "resourceType": { "type": "string", "enum": ["FOLDER", "HIGHLIGHT"] },
          "resourceId": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "accessLevel": { "type": "string", "enum": ["VIEWER", "COMMENTER", "EDITOR"] }
        },
        "databaseOperations": [
          "userRepository.findByEmail(email)",
          "permissionRepository.findByUserIdAndResourceIdAndResourceType(...)",
          "Create or update ResourcePermission with accessLevel",
          "notificationService.emitShareInvite(...)",
          "notificationService.triggerFolderAccessGrantedEmail(...)"
        ],
        "createdTables": ["resource_permissions", "notifications"],
        "httpStatus": 201
      },
      "list": {
        "bffRoute": "GET /api/permissions/{resourceId}?type=FOLDER|HIGHLIGHT",
        "backendEndpoint": "GET /api/v1/permissions/{resourceId}?type=FOLDER|HIGHLIGHT",
        "controller": "PermissionController::list",
        "authRequired": true,
        "accessControl": "OWNER-only",
        "databaseOperations": [
          "permissionRepository.findByResourceIdAndResourceType(resourceId, resourceType)"
        ],
        "httpStatus": 200
      },
      "update": {
        "bffRoute": "PUT /api/permissions/{permissionId}",
        "backendEndpoint": "PUT /api/v1/permissions/{permissionId}",
        "controller": "PermissionController::update",
        "authRequired": true,
        "accessControl": "OWNER-only",
        "requestFields": {
          "accessLevel": { "type": "string", "enum": ["VIEWER", "COMMENTER", "EDITOR"] }
        },
        "httpStatus": 200
      },
      "revoke": {
        "bffRoute": "DELETE /api/permissions/{permissionId}",
        "backendEndpoint": "DELETE /api/v1/permissions/{permissionId}",
        "controller": "PermissionController::revoke",
        "authRequired": true,
        "accessControl": "OWNER-only",
        "databaseOperations": [
          "permissionRepository.deleteById(permissionId)"
        ],
        "httpStatus": 200
      }
    },
    "SHARING": {
      "createShareLink": {
        "bffRoute": "POST /api/share",
        "backendEndpoint": "POST /api/v1/share",
        "controller": "ShareController::create",
        "authRequired": true,
        "accessControl": "OWNER-only",
        "requestFields": {
          "resourceType": { "type": "string", "enum": ["FOLDER", "HIGHLIGHT"] },
          "resourceId": { "type": "string" }
        },
        "databaseOperations": [
          "shareService.createShareLink(user, resourceType, resourceId)",
          "Generate unique 8-char hash",
          "sharedLinkRepository.save(link)"
        ],
        "createdTables": ["shared_links"],
        "httpStatus": 201
      },
      "resolveShareLink": {
        "bffRoute": "GET /api/share/{hash}",
        "backendEndpoint": "GET /api/v1/share/{hash}",
        "controller": "ShareController::resolve",
        "authRequired": false,
        "accessControl": "public (hash-based access)",
        "databaseOperations": [
          "shareService.resolveByHash(hash)",
          "shareService.buildSharedPayload(link)"
        ],
        "httpStatus": 200
      },
      "cloneToLibrary": {
        "bffRoute": "POST /api/share/{hash}/clone",
        "backendEndpoint": "POST /api/v1/share/{hash}/clone",
        "controller": "ShareController::clone",
        "authRequired": true,
        "databaseOperations": [
          "shareService.resolveByHash(hash)",
          "shareService.deepCopyToLibrary(receiver, link) - recursive copy"
        ],
        "httpStatus": 200
      },
      "listSharedWithMe": {
        "bffRoute": "GET /api/share/shared-with-me",
        "backendEndpoint": "GET /api/v1/share/shared-with-me",
        "controller": "ShareController::sharedWithMe",
        "authRequired": true,
        "databaseOperations": [
          "shareService.listSharedWithMe(user)"
        ],
        "httpStatus": 200
      },
      "getResourceForCollab": {
        "bffRoute": "GET /api/share/resource?resourceId=x&type=HIGHLIGHT|FOLDER",
        "backendEndpoint": "GET /api/v1/share/resource?resourceId=x&type=HIGHLIGHT|FOLDER",
        "controller": "ShareController::getResource",
        "authRequired": true,
        "accessControl": "VIEWER-minimum",
        "databaseOperations": [
          "securityService.resolveAccessLevel(resourceId, resourceType)",
          "shareService.buildResourcePayload(resourceId, resourceType)"
        ],
        "httpStatus": 200
      }
    },
    "USER": {
      "getProfile": {
        "bffRoute": "GET /api/user/profile (via /api/auth/me)",
        "backendEndpoint": "GET /api/v1/user/profile",
        "controller": "UserController::getProfile",
        "authRequired": true,
        "databaseOperations": [
          "userRepository.findById(userId)"
        ],
        "httpStatus": 200
      },
      "updateProfile": {
        "bffRoute": "PUT /api/user/profile",
        "backendEndpoint": "PUT /api/v1/user/profile",
        "controller": "UserController::updateProfile",
        "authRequired": true,
        "requestFields": {
          "fullName": { "type": "string", "required": false, "maxLength": 100 },
          "email": { "type": "string", "required": false, "format": "email" },
          "avatarUrl": { "type": "string", "required": false, "maxLength": 500 }
        },
        "databaseOperations": [
          "userRepository.findById(userId)",
          "userRepository.existsByEmail(newEmail) - check duplicate",
          "user.setFullName/setEmail/setAvatarUrl(...)",
          "userRepository.save(user)"
        ],
        "httpStatus": 200
      },
      "changePassword": {
        "bffRoute": "POST /api/user/change-password",
        "backendEndpoint": "POST /api/v1/user/change-password",
        "controller": "UserController::changePassword",
        "authRequired": true,
        "requestFields": {
          "currentPassword": { "type": "string", "required": true },
          "newPassword": { "type": "string", "required": true, "validation": "8-128 chars" }
        },
        "databaseOperations": [
          "userRepository.findById(userId)",
          "passwordEncoder.matches(currentPassword, user.passwordHash)",
          "user.setPasswordHash(passwordEncoder.encode(newPassword))",
          "userRepository.save(user)"
        ],
        "httpStatus": 204
      }
    },
    "NOTIFICATIONS": {
      "list": {
        "bffRoute": "GET /api/notifications",
        "backendEndpoint": "GET /api/v1/notifications",
        "controller": "NotificationController::list",
        "authRequired": true,
        "databaseOperations": [
          "notificationRepository.findByUserIdOrderByCreatedAtDesc(userId)"
        ],
        "httpStatus": 200
      },
      "unreadCount": {
        "bffRoute": "GET /api/notifications/unread-count",
        "backendEndpoint": "GET /api/v1/notifications/unread-count",
        "controller": "NotificationController::unreadCount",
        "authRequired": true,
        "databaseOperations": [
          "notificationRepository.countByUserIdAndIsReadFalse(userId)"
        ],
        "httpStatus": 200
      },
      "markAsRead": {
        "bffRoute": "PUT /api/notifications/{id}/read",
        "backendEndpoint": "PUT /api/v1/notifications/{id}/read",
        "controller": "NotificationController::markRead",
        "authRequired": true,
        "databaseOperations": [
          "notificationRepository.findById(id)",
          "notification.setRead(true)",
          "notificationRepository.save(notification)"
        ],
        "httpStatus": 200
      },
      "markAllAsRead": {
        "bffRoute": "PUT /api/notifications/read-all",
        "backendEndpoint": "PUT /api/v1/notifications/read-all",
        "controller": "NotificationController::markAllRead",
        "authRequired": true,
        "databaseOperations": [
          "notificationRepository.findByUserIdOrderByCreatedAtDesc(userId)",
          "Filter and set all unread to read",
          "notificationRepository.saveAll(unread)"
        ],
        "httpStatus": 200
      },
      "respondToInvite": {
        "bffRoute": "PUT /api/notifications/{id}/respond?action=accept|decline",
        "backendEndpoint": "PUT /api/v1/notifications/{id}/respond?action=accept|decline",
        "controller": "NotificationController::respond",
        "authRequired": true,
        "queryParameters": {
          "action": { "type": "string", "enum": ["accept", "decline"], "required": true }
        },
        "databaseOperations": [
          "notificationRepository.findById(id)",
          "Extract permissionId from metadata JSON",
          "permissionRepository.findById(permissionId)",
          "permission.setStatus(action.toUpperCase())",
          "notification.setResponded(action)",
          "notification.setRead(true)"
        ],
        "httpStatus": 200
      }
    },
    "COMMENTS": {
      "list": {
        "bffRoute": "GET /api/highlights/{highlightId}/comments",
        "backendEndpoint": "GET /api/v1/highlights/{highlightId}/comments",
        "controller": "CommentController::getComments",
        "authRequired": false,
        "databaseOperations": [
          "commentService.getCommentsByHighlight(highlightId)"
        ],
        "httpStatus": 200
      },
      "create": {
        "bffRoute": "POST /api/highlights/{highlightId}/comments",
        "backendEndpoint": "POST /api/v1/highlights/{highlightId}/comments",
        "controller": "CommentController::addComment",
        "authRequired": true,
        "accessControl": "EDITOR or OWNER (VIEWER → 403)",
        "requestFields": {
          "text": { "type": "string", "required": true }
        },
        "databaseOperations": [
          "commentService.addComment(highlightId, text, userId)",
          "Verify RBAC: only EDITOR and OWNER can comment",
          "new Comment(highlight, user, text, Instant.now())",
          "commentRepository.save(comment)"
        ],
        "createdTables": ["comments"],
        "httpStatus": 201
