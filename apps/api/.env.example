# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
# For Supabase: use the Transaction-mode pooler (port 6543), NOT 5432.
# Session mode (5432) caps clients very low (~15) and will crash-loop under load.
DB_HOST=aws-1-eu-west-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.gppcofxrfuxnmgvlpend
DB_PASSWORD=ItzMeYugi@0809
# HikariCP pool sizing — keep small (≤ Supabase pooler limit).
DB_POOL_MIN=1
DB_POOL_MAX=5

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters (256 bits) — generate with:
#   openssl rand -base64 32
CORTEX_JWT_SECRET=/qawHof8BBE5pRWIR+28lQen1bX4A/TAC3Ot5KFzbFs=

# ─── Encryption ────────────────────────────────────────────────────────────────
# 32-byte Base64 key for encrypting sensitive user data
#   openssl rand -base64 32
CORTEX_ENCRYPTION_KEY=+Om5PO7QWYg2pjCqVnt25ETy4DjuYjtbrAc+tfG0ldg=

# ─── Cookie / App URL ──────────────────────────────────────────────────────────
CORTEX_COOKIE_SECURE=true
CORTEX_APP_URL=http://localhost:3000

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (NO wildcards, NO trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Mail (SMTP) ───────────────────────────────────────────────────────────────
CORTEX_MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8080
SPRING_PROFILES_ACTIVE=prod
