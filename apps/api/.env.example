# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters (256 bits) — generate with:
#   openssl rand -base64 32
CORTEX_JWT_SECRET=

# ─── Encryption ────────────────────────────────────────────────────────────────
# 32-byte Base64 key for encrypting sensitive user data
#   openssl rand -base64 32
CORTEX_ENCRYPTION_KEY=

# ─── Cookie / App URL ──────────────────────────────────────────────────────────
CORTEX_COOKIE_SECURE=true
CORTEX_APP_URL=http://localhost:3000

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (NO wildcards, NO trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Mail (SMTP) ───────────────────────────────────────────────────────────────
CORTEX_MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8080
SPRING_PROFILES_ACTIVE=prod
